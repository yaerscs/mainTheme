{%- style -%}
  .advrj *, .advrj *::before, .advrj *::after { box-sizing: border-box; }
  .advrj { background: #fff; color: #333; }

  /* ── Top Bar ── */
  .advrj-topbar {
    background: {{ section.settings.topbar_bg }};
    color: {{ section.settings.topbar_color }};
    text-align: center;
    padding: 10px 16px;
    font-family: 'Alegreya', Georgia, serif;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.2;
  }

  /* ── Layout ── */
  .advrj-wrap { max-width: 1120px; margin: 0 auto; padding: 0 16px; }
  .advrj-cols { display: flex; gap: 22px; padding-bottom: 60px; align-items: flex-start; }
  .advrj-main { flex: 0 0 62%; min-width: 0; }
  .advrj-sidebar {
    flex: 0 0 36%;
    min-width: 0;
    border-left: 1px solid #e4e4e4;
    padding-left: 18px;
    padding-top: 8px;
  }

  /* ── Breadcrumb ── */
  .advrj-breadcrumb {
    padding: 14px 0 6px;
    font-family: Poppins, Arial, sans-serif;
    font-size: 12px;
    color: #888;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
  }
  .advrj-breadcrumb a { color: #1a6496; text-decoration: none; }
  .advrj-breadcrumb a:hover { text-decoration: underline; }
  .advrj-breadcrumb .sep { color: #ccc; }

  /* ── Article Header ── */
  .advrj-main h1 {
    font-family: 'Bitter', Georgia, serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.3;
    color: #111;
    margin: 14px 0 16px;
  }
  .advrj-byline {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid #e4e4e4;
    border-radius: 4px;
    padding: 12px 16px;
    margin-bottom: 20px;
    background: #fafafa;
  }
  .advrj-byline-ava {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: #cdd9e5;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px; color: #2c5f8a;
    flex-shrink: 0; overflow: hidden;
  }
  .advrj-byline-ava img { width: 100%; height: 100%; object-fit: cover; }
  .advrj-byline-text { font-family: Poppins, Arial, sans-serif; font-size: 12px; color: #666; line-height: 1.5; }
  .advrj-byline-text strong { display: block; color: #111; font-size: 13px; }

  /* ── Images ── */
  .advrj-img { margin: 18px 0; width: 100%; }
  .advrj-img img { width: 100%; height: auto; display: block; border-radius: 4px; }
  .advrj-img-caption { font-size: 11px; color: #999; font-style: italic; text-align: center; margin-top: 5px; font-family: Poppins, Arial, sans-serif; }
  .advrj-placeholder {
    width: 100%; background: #e8eef5;
    border: 2px dashed #a8bece; border-radius: 4px;
    min-height: 240px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 20px;
    color: #4a6f8a;
  }
  .advrj-placeholder .ph-lbl { font-weight: 700; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; font-family: Poppins, Arial, sans-serif; }
  .advrj-placeholder .ph-desc { font-size: 11px; color: #7a99b0; max-width: 340px; line-height: 1.5; font-family: Poppins, Arial, sans-serif; }

  /* Before/After pair */
  .advrj-ba { display: flex; gap: 8px; margin: 18px 0; }
  .advrj-ba-item { flex: 1; position: relative; }
  .advrj-ba-item img { width: 100%; height: auto; display: block; border-radius: 4px; }
  .advrj-ba-placeholder { background: #dce8f3; border: 2px dashed #a8bece; border-radius: 4px; min-height: 180px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: #4a6f8a; text-transform: uppercase; letter-spacing: 0.5px; text-align: center; padding: 12px; font-family: Poppins, Arial, sans-serif; }
  .advrj-ba-label { position: absolute; top: 6px; left: 6px; background: rgba(0,0,0,0.6); color: #fff; font-size: 10px; font-weight: 700; padding: 3px 7px; border-radius: 3px; letter-spacing: 1px; text-transform: uppercase; font-family: Poppins, Arial, sans-serif; }

  /* Body text */
  .advrj-main p { font-family: 'Bitter', Georgia, serif; font-size: 17px; line-height: 1.75; color: #303030; margin-bottom: 14px; }
  .advrj-body-text p { font-family: 'Bitter', Georgia, serif; font-size: 17px; line-height: 1.75; color: #303030; margin-bottom: 14px; }
  .advrj-body-text strong { color: #111; }
  .advrj-body-text ul { list-style: disc; padding-left: 22px; margin: 10px 0 16px; }
  .advrj-body-text ul li { font-family: 'Bitter', Georgia, serif; font-size: 16px; color: #303030; margin-bottom: 7px; line-height: 1.7; }
  .advrj-body-text ol { padding-left: 22px; margin: 10px 0 16px; }
  .advrj-body-text ol li { font-family: 'Bitter', Georgia, serif; font-size: 16px; color: #303030; margin-bottom: 7px; line-height: 1.7; }
  .advrj-main h2 {
    font-family: 'Bitter', Georgia, serif;
    font-size: 17px;
    font-weight: 700;
    color: #111;
    line-height: 1.3;
    margin: 32px 0 14px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  /* Callout box */
  .advrj-callout {
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 4px;
    padding: 14px 18px;
    margin: 18px 0;
    font-family: 'Bitter', Georgia, serif;
    font-size: 17px;
    font-weight: 600;
    line-height: 1.6;
    color: #333;
  }

  /* Feature ticks */
  .advrj-ticks { background: #eef4fb; border: 1px solid #c0d6ed; border-radius: 4px; padding: 16px 20px; margin: 18px 0; }
  .advrj-ticks p { font-family: 'Bitter', Georgia, serif; font-size: 15px; color: #1a3053; margin-bottom: 8px; line-height: 1.6; }
  .advrj-ticks p:last-child { margin-bottom: 0; }

  /* Review card */
  .advrj-review { border: 1px solid #ddd; border-radius: 5px; padding: 16px 18px; margin: 14px 0; background: #fff; }
  .advrj-review .stars { color: #f39c12; font-size: 14px; margin-bottom: 4px; }
  .advrj-review .r-name { font-weight: 700; font-size: 13px; color: #111; font-family: Poppins, Arial, sans-serif; }
  .advrj-review .r-loc { font-size: 11.5px; color: #999; margin-bottom: 8px; font-family: Poppins, Arial, sans-serif; }
  .advrj-review p { font-size: 13.5px; font-style: italic; color: #444; margin-bottom: 0; font-family: 'Bitter', Georgia, serif; line-height: 1.6; }

  /* CTA Button */
  .advrj-cta-wrap { margin: 18px 0 6px; }
  .advrj-cta {
    display: block;
    width: 100%;
    background: {{ section.settings.cta_color }};
    color: #fff !important;
    font-family: Poppins, Arial, sans-serif;
    font-size: 18px;
    font-weight: 700;
    text-align: center;
    padding: 18px 20px;
    border-radius: 5px;
    text-decoration: none;
    line-height: 1.4;
    transition: opacity 0.2s ease;
  }
  .advrj-cta:hover { opacity: 0.88; }
  .advrj-cta-sub { font-size: 12px; text-align: center; color: #888; font-family: Poppins, Arial, sans-serif; margin-top: 6px; margin-bottom: 14px; }

  /* Urgency box */
  .advrj-urgency { background: #fffbeb; border: 2px dashed #d0021b; border-radius: 4px; padding: 14px 18px; margin: 18px 0; font-family: 'Bitter', Georgia, serif; font-size: 17px; font-weight: 700; text-align: center; color: #d0021b; line-height: 1.4; }

  /* Guarantee */
  .advrj-guarantee { text-align: center; margin: 20px 0; }
  .advrj-guarantee img { max-width: 340px; width: 100%; border-radius: 6px; }

  /* Final offer box */
  .advrj-finalbox { border: 2px solid #ddd; border-radius: 6px; padding: 22px 18px; margin: 20px 0; text-align: center; background: #fafafa; }

  /* ── SIDEBAR ── */
  .advrj-sb-headline { font-family: Poppins, Arial, sans-serif; font-size: 12.5px; font-weight: 600; color: #444; line-height: 1.55; margin-bottom: 12px; }
  .advrj-sb-imgwrap { margin-bottom: 10px; }
  .advrj-sb-imgwrap img { width: 100%; height: auto; display: block; border-radius: 4px; }
  .advrj-sb-desc { font-family: Poppins, Arial, sans-serif; font-size: 12px; color: #555; line-height: 1.6; margin-bottom: 14px; }
  .advrj-sb-results-headline { font-family: Poppins, Arial, sans-serif; font-size: 12.5px; font-weight: 600; color: #333; margin-bottom: 12px; line-height: 1.5; }
  .advrj-sb-item { margin-bottom: 20px; }
  .advrj-sb-item img { width: 100%; height: auto; display: block; border-radius: 4px; margin-bottom: 5px; }
  .advrj-sb-item .sb-placeholder { background: #ebebeb; border: 2px dashed #bbb; border-radius: 4px; min-height: 160px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px; font-family: Poppins, Arial, sans-serif; }
  .advrj-sb-item .sb-caption { font-size: 10px; color: #aaa; font-style: italic; text-align: center; font-family: Poppins, Arial, sans-serif; margin-bottom: 4px; }
  .advrj-sb-item .sb-name { font-size: 12.5px; font-weight: 700; color: #111; font-family: Poppins, Arial, sans-serif; margin-bottom: 4px; }
  .advrj-sb-item .sb-quote { font-size: 11.5px; font-style: italic; color: #444; line-height: 1.55; font-family: Poppins, Arial, sans-serif; margin-bottom: 8px; border-left: 2px solid #e0e0e0; padding-left: 8px; }
  .advrj-sb-btn {
    display: block;
    background: {{ section.settings.cta_color }};
    color: #fff !important;
    font-family: Poppins, Arial, sans-serif;
    font-size: 13px; font-weight: 700;
    text-align: center;
    padding: 10px 14px;
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .advrj-sb-btn:hover { opacity: 0.88; }

  /* ── Footer ── */
  .advrj-footer { background: #1a1a1a; color: #777; padding: 26px 16px; font-size: 11px; line-height: 1.8; text-align: center; }
  .advrj-footer .inner { max-width: 1120px; margin: 0 auto; }
  .advrj-footer a { color: #aaa; }
  .advrj-footer p { color: #777; font-size: 11px; line-height: 1.8; margin-bottom: 8px; font-family: Arial, sans-serif; }

  /* ── Responsive ── */
  @media (max-width: 780px) {
    .advrj-cols { flex-direction: column; }
    .advrj-main, .advrj-sidebar { flex: none; width: 100%; }
    .advrj-sidebar { border-left: none; padding-left: 0; border-top: 2px solid #e4e4e4; padding-top: 24px; margin-top: 0; }
    .advrj-main h1 { font-size: 22px; }
    .advrj-main h2 { font-size: 15px; }
    .advrj-main p, .advrj-body-text p { font-size: 15px; }
    .advrj-cta { font-size: 16px; }
    .advrj-ba { flex-direction: column; }
  }
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,600;0,700;1,400&family=Alegreya:wght@700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<div class="advrj">

  <!-- Top Bar -->
  <div class="advrj-topbar">{{ section.settings.topbar_text | escape }}</div>

  <div class="advrj-wrap">
    <div class="advrj-cols">

      <!-- ═══════════════════════════════════════════ -->
      <!--                ARTICLE COLUMN               -->
      <!-- ═══════════════════════════════════════════ -->
      <article class="advrj-main">

        <!-- Breadcrumb -->
        <nav class="advrj-breadcrumb" aria-label="breadcrumb">
          <a href="{{ section.settings.bc1_url | default: '/' }}">{{ section.settings.bc1_text | default: 'Home' | escape }}</a>
          <span class="sep">›</span>
          <a href="{{ section.settings.bc2_url | default: '/collections/all' }}">{{ section.settings.bc2_text | default: 'Health' | escape }}</a>
          <span class="sep">›</span>
          <span>{{ section.settings.bc3_text | default: 'Shoulder Health' | escape }}</span>
        </nav>

        <!-- Title -->
        <h1>{{ section.settings.article_title | escape }}</h1>

        <!-- Byline -->
        <div class="advrj-byline">
          <div class="advrj-byline-ava">
            {%- if section.settings.author_image != blank -%}
              {{ section.settings.author_image | image_url: width: 88 | image_tag: loading: 'lazy', alt: section.settings.author_name }}
            {%- else -%}
              {{ section.settings.author_initials | default: 'BS' | escape }}
            {%- endif -%}
          </div>
          <div class="advrj-byline-text">
            <strong>{{ section.settings.author_name | escape }}{% if section.settings.author_title != blank %}, {{ section.settings.author_title | escape }}{% endif %}</strong>
            {{ section.settings.article_date | escape }}
            {%- if section.settings.reading_time != blank -%}
              &nbsp;&nbsp;·&nbsp;&nbsp;{{ section.settings.reading_time | escape }} read
            {%- endif -%}
          </div>
        </div>

        <!-- Hero Image -->
        <div class="advrj-img">
          {%- if section.settings.hero_image != blank -%}
            {{ section.settings.hero_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: section.settings.hero_caption }}
          {%- else -%}
            <div class="advrj-placeholder" style="min-height:300px;">
              <div class="ph-lbl">Hero Image</div>
              <div class="ph-desc">Main article hero image — e.g. woman using shoulder device, relaxing on couch.</div>
            </div>
          {%- endif -%}
          {%- if section.settings.hero_caption != blank -%}
            <div class="advrj-img-caption">{{ section.settings.hero_caption | escape }}</div>
          {%- endif -%}
        </div>

        <!-- Opening Content -->
        {%- if section.settings.content_opening != blank -%}
          <div class="advrj-body-text">{{ section.settings.content_opening }}</div>
        {%- else -%}
          <p style="color:#bbb;font-style:italic;font-family:Poppins,Arial,sans-serif;font-size:13px;">[Opening paragraphs — edit in theme customizer]</p>
        {%- endif -%}

        <!-- ─── SECTION 1 ─── -->
        <h2>{{ section.settings.s1_title | default: 'THE NIGHT EVERYTHING CHANGED...' | escape }}</h2>

        <div class="advrj-ba">
          <div class="advrj-ba-item">
            {%- if section.settings.img_s1_left != blank -%}
              {{ section.settings.img_s1_left | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder">Left Image<br>(e.g. woman in pain at night)</div>
            {%- endif -%}
          </div>
          <div class="advrj-ba-item">
            {%- if section.settings.img_s1_right != blank -%}
              {{ section.settings.img_s1_right | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder">Right Image<br>(e.g. alarm clock at 3am)</div>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.content_s1 != blank -%}
          <div class="advrj-body-text">{{ section.settings.content_s1 }}</div>
        {%- else -%}
          <p style="color:#bbb;font-style:italic;font-family:Poppins,Arial,sans-serif;font-size:13px;">[Section 1 body — edit in theme customizer]</p>
        {%- endif -%}

        <!-- ─── SECTION 2 ─── -->
        <h2>{{ section.settings.s2_title | default: 'THE MIND BLOWING DISCOVERY' | escape }}</h2>

        <div class="advrj-ba">
          <div class="advrj-ba-item">
            {%- if section.settings.img_s2_left != blank -%}
              {{ section.settings.img_s2_left | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder">Left Image<br>(e.g. doctor researching)</div>
            {%- endif -%}
          </div>
          <div class="advrj-ba-item">
            {%- if section.settings.img_s2_right != blank -%}
              {{ section.settings.img_s2_right | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder">Right Image<br>(e.g. shoulder pain highlighted)</div>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.content_s2 != blank -%}
          <div class="advrj-body-text">{{ section.settings.content_s2 }}</div>
        {%- else -%}
          <p style="color:#bbb;font-style:italic;font-family:Poppins,Arial,sans-serif;font-size:13px;">[Section 2 body — edit in theme customizer]</p>
        {%- endif -%}

        <!-- ─── SECTION 3 ─── -->
        <h2>{{ section.settings.s3_title | default: 'THE REAL ROOT CAUSE OF ROTATOR CUFF PAIN' | escape }}</h2>

        <div class="advrj-ba">
          <div class="advrj-ba-item">
            {%- if section.settings.img_s3_left != blank -%}
              {{ section.settings.img_s3_left | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder">Left Image<br>(e.g. door hinge)</div>
            {%- endif -%}
          </div>
          <div class="advrj-ba-item">
            {%- if section.settings.img_s3_right != blank -%}
              {{ section.settings.img_s3_right | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder">Right Image<br>(e.g. tissue / microscope)</div>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.content_s3 != blank -%}
          <div class="advrj-body-text">{{ section.settings.content_s3 }}</div>
        {%- else -%}
          <p style="color:#bbb;font-style:italic;font-family:Poppins,Arial,sans-serif;font-size:13px;">[Section 3 body — edit in theme customizer]</p>
        {%- endif -%}

        <!-- ─── SECTION 4: 12-Minute Miracle ─── -->
        <h2>{{ section.settings.s4_title | default: 'THE 12-MINUTE MIRACLE HIDING IN PLAIN SIGHT' | escape }}</h2>

        <div class="advrj-ba">
          <div class="advrj-ba-item">
            <div class="advrj-ba-label">BEFORE</div>
            {%- if section.settings.img_s4_before != blank -%}
              {{ section.settings.img_s4_before | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder" style="min-height:220px;">Before Image</div>
            {%- endif -%}
          </div>
          <div class="advrj-ba-item">
            <div class="advrj-ba-label">AFTER</div>
            {%- if section.settings.img_s4_after != blank -%}
              {{ section.settings.img_s4_after | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder" style="min-height:220px;">After Image</div>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.content_s4 != blank -%}
          <div class="advrj-body-text">{{ section.settings.content_s4 }}</div>
        {%- else -%}
          <p style="color:#bbb;font-style:italic;font-family:Poppins,Arial,sans-serif;font-size:13px;">[Section 4 body — edit in theme customizer]</p>
        {%- endif -%}

        <!-- Feature Ticks -->
        <div class="advrj-ticks">
          <p>✓ <strong>{{ section.settings.feature_1_title | default: 'HEAT' | escape }}</strong> — {{ section.settings.feature_1_desc | default: 'Open the blood vessels so circulation can reach starved tissue' | escape }}</p>
          <p>✓ <strong>{{ section.settings.feature_2_title | default: 'COMPRESS' | escape }}</strong> — {{ section.settings.feature_2_desc | default: 'Force fresh blood and nutrients through the joint' | escape }}</p>
          <p>✓ <strong>{{ section.settings.feature_3_title | default: 'VIBRATE' | escape }}</strong> — {{ section.settings.feature_3_desc | default: 'Stimulate cellular regeneration and muscle reset' | escape }}</p>
        </div>

        <!-- ─── SECTION 5: Breakthrough ─── -->
        <h2>{{ section.settings.s5_title | default: 'THIS BREAKTHROUGH IS PISSING OFF AN ENTIRE INDUSTRY' | escape }}</h2>

        <div class="advrj-ba">
          <div class="advrj-ba-item">
            <div class="advrj-ba-label">BEFORE</div>
            {%- if section.settings.img_s5_before != blank -%}
              {{ section.settings.img_s5_before | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder">Before Image</div>
            {%- endif -%}
          </div>
          <div class="advrj-ba-item">
            <div class="advrj-ba-label">AFTER</div>
            {%- if section.settings.img_s5_after != blank -%}
              {{ section.settings.img_s5_after | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div class="advrj-ba-placeholder">After Image</div>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.content_s5 != blank -%}
          <div class="advrj-body-text">{{ section.settings.content_s5 }}</div>
        {%- else -%}
          <p style="color:#bbb;font-style:italic;font-family:Poppins,Arial,sans-serif;font-size:13px;">[Section 5 body — edit in theme customizer]</p>
        {%- endif -%}

        <!-- ─── SECTION 6: Introducing the Device ─── -->
        <h2>{{ section.settings.s6_title | default: 'INTRODUCING THE DEVICE THAT ACTUALLY RELIEVES SHOULDER PAIN' | escape }}</h2>

        <div class="advrj-ba">
          {%- for i in (1..3) -%}
            {%- assign img_key = 'img_product_' | append: i -%}
            <div class="advrj-ba-item">
              {%- if section.settings[img_key] != blank -%}
                {{ section.settings[img_key] | image_url: width: 400 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <div class="advrj-ba-placeholder" style="min-height:140px;font-size:10px;">Product Image {{ i }}</div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.content_s6 != blank -%}
