        "checksum": "5fd09ba17144843ee6a64c3f27d3e0ff57e42a378df20d3614831a2fa52015c9_0_1_1_0__1",
        "gg0xBVISNIu_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0809/8739/0192/files/hf_20260306_110622_b91e79d5-46ea-473f-b7fa-9c0614e78dec.png",
