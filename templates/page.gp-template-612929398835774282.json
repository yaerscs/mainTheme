        "gg4_hAqfcUI_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0809/8739/0192/files/istockphoto-121546719-612x612.jpg",
        "gg6Cfe6f29k_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0809/8739/0192/files/Gemini_Generated_Image_6qy0cd6qy0cd6qy0_1.png",
