    <script>

      const COLLAPSED_STATE_KEY = 'shogun_price_test_sidebar_collapsed_state';
      const DESCRIPTION_HEIGHT_STATE_KEY = 'shogun_price_test_sidebar_description_heights';
      const DESCRIPTION_HEIGHT_SAVE_DELAY_MS = 120;
      const descriptionHeightSaveTimers = {};
      const pendingDescriptionHeights = {};
      let descriptionHeightResizeObserver = null;
      let descriptionHeightFlushHandlersBound = false;

      function saveCollapsedState(elementId, isCollapsed) {
        try {
          const state = JSON.parse(localStorage.getItem(COLLAPSED_STATE_KEY) || '{}');
          state[elementId] = isCollapsed;
          localStorage.setItem(COLLAPSED_STATE_KEY, JSON.stringify(state));
        } catch (e) {
          console.warn('Failed to save collapsed state:', e);
        }
      }

      function restoreCollapsedState() {
        try {
          const state = JSON.parse(localStorage.getItem(COLLAPSED_STATE_KEY) || '{}');

          Object.keys(state).forEach(elementId => {
            const element = document.getElementById(elementId);
            if (element) {
              const caret = element.previousElementSibling?.querySelector('.shg-preview__product-caret');

              if (state[elementId]) {
                element.classList.add('collapsed');
                if (caret) {
                  caret.classList.add('collapsed');
                }
              } else {
                element.classList.remove('collapsed');
                if (caret) {
                  caret.classList.remove('collapsed');
                }
              }
            }
          });
        } catch (e) {
          console.warn('Failed to restore collapsed state:', e);
        }
      }

      function getDescriptionHeightState() {
        try {
          const parsed = JSON.parse(localStorage.getItem(DESCRIPTION_HEIGHT_STATE_KEY) || '{}');
          if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return {};
          return parsed;
        } catch (e) {
          console.warn('Failed to read description height state:', e);
          return {};
        }
      }

      function saveDescriptionHeightState(heightKey, heightPx) {
        if (!heightKey || !Number.isFinite(heightPx) || heightPx <= 0) return;

        try {
          const state = getDescriptionHeightState();
          state[heightKey] = Math.round(heightPx);
          localStorage.setItem(DESCRIPTION_HEIGHT_STATE_KEY, JSON.stringify(state));
        } catch (e) {
          console.warn('Failed to save description height state:', e);
        }
      }

      function queueDescriptionHeightStateSave(heightKey, heightPx) {
        if (!heightKey || !Number.isFinite(heightPx) || heightPx <= 0) return;

        pendingDescriptionHeights[heightKey] = heightPx;

        if (descriptionHeightSaveTimers[heightKey]) {
          clearTimeout(descriptionHeightSaveTimers[heightKey]);
        }

        descriptionHeightSaveTimers[heightKey] = setTimeout(() => {
          const pendingHeight = pendingDescriptionHeights[heightKey];
          saveDescriptionHeightState(heightKey, pendingHeight);
          delete pendingDescriptionHeights[heightKey];
          delete descriptionHeightSaveTimers[heightKey];
        }, DESCRIPTION_HEIGHT_SAVE_DELAY_MS);
      }

      function flushDescriptionHeightStateSaves() {
        Object.keys(pendingDescriptionHeights).forEach((heightKey) => {
          if (descriptionHeightSaveTimers[heightKey]) {
            clearTimeout(descriptionHeightSaveTimers[heightKey]);
            delete descriptionHeightSaveTimers[heightKey];
          }

          const pendingHeight = pendingDescriptionHeights[heightKey];
          saveDescriptionHeightState(heightKey, pendingHeight);
          delete pendingDescriptionHeights[heightKey];
        });
      }

      function bindDescriptionHeightFlushHandlers() {
        if (descriptionHeightFlushHandlersBound) return;
        descriptionHeightFlushHandlersBound = true;

        window.addEventListener('beforeunload', flushDescriptionHeightStateSaves);
        window.addEventListener('pagehide', flushDescriptionHeightStateSaves);
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') {
            flushDescriptionHeightStateSaves();
          }
        });
      }

      function getDescriptionHeightResizeObserver() {
        if (typeof ResizeObserver !== 'function') return null;

        if (!descriptionHeightResizeObserver) {
          descriptionHeightResizeObserver = new ResizeObserver((entries) => {
            entries.forEach((entry) => {
              const target = entry.target;
              const heightKey = target && target.getAttribute ? target.getAttribute('data-height-key') : null;
              if (!heightKey) return;
              queueDescriptionHeightStateSave(heightKey, entry.contentRect.height);
            });
          });
        }

        return descriptionHeightResizeObserver;
      }

      function restoreDescriptionHeightState() {
        bindDescriptionHeightFlushHandlers();
        const state = getDescriptionHeightState();

        const descriptionElements = document.querySelectorAll('.shg-preview__variant-description[data-height-key]');
        const resizeObserver = getDescriptionHeightResizeObserver();
        descriptionElements.forEach((element) => {
          const heightKey = element.getAttribute('data-height-key');
          if (!heightKey) return;

          const savedHeight = Number(state[heightKey]);
          if (Number.isFinite(savedHeight) && savedHeight > 0) {
            element.style.height = `${savedHeight}px`;
          }

          if (resizeObserver) {
            if (element.getAttribute('data-height-observer-bound') === 'true') return;
            resizeObserver.observe(element);
            element.setAttribute('data-height-observer-bound', 'true');
          } else {
            if (element.getAttribute('data-height-fallback-bound') === 'true') return;
            element.addEventListener('mouseup', () => {
              const computedHeight = Number.parseFloat(getComputedStyle(element).height);
              saveDescriptionHeightState(heightKey, computedHeight);
            });
            element.addEventListener('touchend', () => {
              const computedHeight = Number.parseFloat(getComputedStyle(element).height);
              saveDescriptionHeightState(heightKey, computedHeight);
            });
            element.setAttribute('data-height-fallback-bound', 'true');
          }
        });
      }

      function toggleElement(elementId) {
        const children = document.getElementById(elementId);
        if (!children) return;
        const caret = children.previousElementSibling?.querySelector('.shg-preview__product-caret');
        if (!caret) return;

        if (children.classList.contains('collapsed')) {
          // Expand: remove collapsed class first, then rotate caret
          children.classList.remove('collapsed');
          caret.classList.remove('collapsed');
          saveCollapsedState(elementId, false);
        } else {
          // Collapse: add collapsed class, then rotate caret
          children.classList.add('collapsed');
          caret.classList.add('collapsed');
          saveCollapsedState(elementId, true);
        }
      }

      function toggleProduct(productId) {
        toggleElement(productId);
      }

      function contactSupport() {
        const subject = encodeURIComponent('A/B Testing Question');
        const body = encodeURIComponent('Hi Shogun Team,\n\n');
        const mailtoLink = `mailto:support-ab@getshogun.com?subject=${subject}&body=${body}`;
        window.open(mailtoLink, '_blank');
      }

      window.restoreCollapsedState = restoreCollapsedState;
      window.restoreDescriptionHeightState = restoreDescriptionHeightState;
      window.flushDescriptionHeightStateSaves = flushDescriptionHeightStateSaves;
    </script>
  {% endif %}
{%- endif -%}

{%- comment -%}
  =====================================================
