{%- endcomment -%}
<script type="text/javascript">
  ;(function() {
    const designMode = {{ request.design_mode | default: false }};
    if (designMode) {
      console.debug("shogun: Design mode is enabled, skipping optimizer initialization");
      return;
    }

    // If the referrer url is the Shopify admin url or other known merchant domains, then set a local storage shg_is_merchant flag to true
    // This is used to remove the preview bar from the page for shoppers
    const referrer = document.referrer
    const merchantDomains = ['admin.shopify.com', 'ab.shgapi.com', 'abc.shogun.dev']
    if (!localStorage.getItem('_shg_is_merchant') && merchantDomains.some(domain => referrer.includes(domain))) {
      console.debug('shogun: Setting shg_is_merchant to true')
      localStorage.setItem('_shg_is_merchant', 'true')
    }

    // Check for optimization disable flags
    const urlParams = new URLSearchParams(window.location.search);
    const optimizationDisabled = urlParams.get('shg') === "false" || window.location.hostname.includes('shopifypreview');

    if (optimizationDisabled) {
      console.debug("shogun: Optimization is disabled, skipping optimizer initialization");
      return;
    }

    // Load shop metafield configuration
    {% if shop.metafields.shgabc.optimizations %}
    const shopMetafieldConfig = {{ shop.metafields.shgabc.optimizations }};
    {% else %}
    const shopMetafieldConfig = null;
    {% endif %}
    if (!shopMetafieldConfig) {
      console.debug("shogun: Shop metafield configuration for optimizations is missing. Skipping optimizer initialization.");
      return;
    }

    const optimizationsData = shopMetafieldConfig.expires_at > Date.now() ? (shopMetafieldConfig.optimizations || []) : [];

    // These ID should match. It is possible for them to be different if a theme is copied from a different shop.
    const intendedShopifyId = "80987390192"; // The hard coded shopify ID when this snippet was pushed to the theme.
    const currentShopifyId = "{{ shop.id }}"; // The current shopify ID that this theme is rendered in.
    if (intendedShopifyId !== currentShopifyId) {
      console.debug(`shogun: Shopify ID mismatch: intendedShopifyId=${intendedShopifyId} currentShopifyId=${currentShopifyId}. This may indicate the theme was copied from another shop and not properly set up. Skipping optimizer initialization to avoid potential issues.`);
      return;
    } else {
      console.debug(`shogun: Shopify ID verified: ${intendedShopifyId}`);
    }

    
      if (typeof ShogunDispatcher === 'undefined') {
        console.error("shogun: Dispatcher is not defined. Please ensure the shogun optimizer script is properly loaded.");
        return;
      }

      const dispatcherConfig = {
        shop: {
          shopId: "f1b541be-0c6c-484c-ac5e-536c88dd344f",
          shopDomain: "s3x280-0x.myshopify.com",
          analyticsUrl: "https://shogun-abc-production.global.ssl.fastly.net",
          geoLocationApi: "https://ipinfo.io/json?token=f2ae3a557d807b",
          storefrontAccessToken: "bbe4444ab1c446a5afde296a6bb36fbe",
          defaultThemeId: shopMetafieldConfig.default_theme_id ? shopMetafieldConfig.default_theme_id.toString() : null,
        },
        page: {
          pageId: "{{ content.id }}",
          pageType: "{% if template.name == 'list-collections' %}list-collections{% elsif article %}article{% elsif blog %}blog{% elsif page %}page{% elsif product %}product{% elsif collection %}collection{% elsif metaobject %}metaobject{% else %}homepage{% endif %}",
          templateName: "{{ template.name }}",
          templateSuffix: "{{ template.suffix }}",
          themeId: "160758595824",
          languageRootUrl: "{{ localization.language.root_url }}",
          path: window.location.pathname,
          currentCartVariantId: {% if cart.attributes.shogun_variant_id %}"{{ cart.attributes.shogun_variant_id }}"{% else %}null{% endif %},
        },
        session: {
          sessionId: urlParams.get('shgSessionId'),
          customerId: "{{ customer.id }}",
          isB2B: {{ customer.b2b? | default: false }},
        },
        assignmentStrategy: shopMetafieldConfig.method,
        publishedOptimizations: optimizationsData
      }

      console.debug("shogun: Initializing ShogunOptimizer v2");
      const dispatcher = new ShogunDispatcher(dispatcherConfig);
      dispatcher.run();
    
  })();

</script>
